{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markdown Pad",
  "version": "0.1.0",
  "identifier": "app.markdownpad.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Markdown Pad",
        "width": 1100,
        "height": 820,
        "minWidth": 760,
        "minHeight": 520,
        "resizable": true,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"],
    "category": "Productivity",
    "shortDescription": "Fast WYSIWYG Markdown editor",
    "longDescription": "Markdown Pad is a fast WYSIWYG Markdown editor for Windows with clean printing.",
    "fileAssociations": [
      {
        "ext": ["md"],
        "name": "Markdown Document",
        "description": "Markdown Document",
        "mimeType": "text/markdown",
        "role": "Editor",
        "rank": "Default"
      }
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      },
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "displayLanguageSelector": false
      }
    }
  }
}
